{
  "skill_name": "knowledge-base",
  "description": "测试 Knowledge Base Skill 的各种场景",
  "evals": [
    {
      "id": 1,
      "name": "kb_list_query",
      "prompt": "有哪些知识库？",
      "expected_output": "列出所有可用的知识库，显示名称、路径和笔记数量",
      "assertions": [
        {
          "type": "contains",
          "target": "output",
          "value": "知识库"
        }
      ]
    },
    {
      "id": 2,
      "name": "kb_switch_explicit",
      "prompt": "切换到 work 知识库",
      "expected_output": "确认切换到 work 知识库，并更新上下文",
      "assertions": [
        {
          "type": "contains",
          "target": "output",
          "value": "work"
        }
      ]
    },
    {
      "id": 3,
      "name": "note_add_simple",
      "prompt": "记录一个想法：AI 的发展速度很快",
      "expected_output": "创建一条 fleeting 类型的笔记，标题包含日期",
      "assertions": [
        {
          "type": "contains",
          "target": "output",
          "value": "笔记已创建"
        },
        {
          "type": "contains",
          "target": "output",
          "value": "fleeting"
        }
      ]
    },
    {
      "id": 4,
      "name": "note_add_with_title",
      "prompt": "添加笔记：学习 Rust 的心得，标题是 Rust 学习",
      "expected_output": "创建指定标题的笔记",
      "assertions": [
        {
          "type": "contains",
          "target": "output",
          "value": "Rust 学习"
        }
      ]
    },
    {
      "id": 5,
      "name": "note_add_with_kb",
      "prompt": "在个人库中记录：今天天气很好",
      "expected_output": "在 personal 知识库中创建笔记",
      "assertions": [
        {
          "type": "contains",
          "target": "output",
          "value": "personal"
        }
      ]
    },
    {
      "id": 6,
      "name": "note_add_template_meeting",
      "prompt": "用 meeting 模板创建一个会议记录，关于产品周会",
      "expected_output": "使用 meeting 模板创建 permanent 类型的笔记",
      "assertions": [
        {
          "type": "contains",
          "target": "output",
          "value": "meeting"
        },
        {
          "type": "contains",
          "target": "output",
          "value": "permanent"
        }
      ]
    },
    {
      "id": 7,
      "name": "note_search_simple",
      "prompt": "搜索 Python 相关的笔记",
      "expected_output": "返回包含 Python 关键词的笔记列表",
      "assertions": [
        {
          "type": "contains",
          "target": "output",
          "value": "Python"
        }
      ]
    },
    {
      "id": 8,
      "name": "note_list_recent",
      "prompt": "列出最近的笔记",
      "expected_output": "显示最近创建的笔记列表",
      "assertions": [
        {
          "type": "contains",
          "target": "output",
          "value": "笔记"
        }
      ]
    },
    {
      "id": 9,
      "name": "template_list",
      "prompt": "有哪些模板可用？",
      "expected_output": "列出所有可用模板（quick, meeting, literature）",
      "assertions": [
        {
          "type": "contains",
          "target": "output",
          "value": "quick"
        },
        {
          "type": "contains",
          "target": "output",
          "value": "meeting"
        },
        {
          "type": "contains",
          "target": "output",
          "value": "literature"
        }
      ]
    },
    {
      "id": 10,
      "name": "kb_status",
      "prompt": "查看知识库状态",
      "expected_output": "显示知识库的统计信息",
      "assertions": [
        {
          "type": "contains",
          "target": "output",
          "value": "状态"
        }
      ]
    },
    {
      "id": 11,
      "name": "context_continuation",
      "prompt": "再记录一个",
      "expected_output": "继续在上一个知识库中创建笔记",
      "context": {
        "current_kb": "work"
      },
      "assertions": [
        {
          "type": "contains",
          "target": "output",
          "value": "work"
        }
      ]
    },
    {
      "id": 12,
      "name": "kb_create_new",
      "prompt": "创建一个学习知识库，名字叫 study",
      "expected_output": "创建新的知识库并初始化",
      "assertions": [
        {
          "type": "contains",
          "target": "output",
          "value": "study"
        }
      ]
    }
  ]
}
